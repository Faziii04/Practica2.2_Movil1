<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    tools:ignore="ContentDescription,SpeakableTextPresentCheck">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDoctorNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/item_doctor_nombre"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDoctorEspecialidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/item_doctor_especialidad"
                android:textColor="#CBD5E1"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEditarDoctor"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/item_doctor_editar"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#22C55E"
            tools:ignore="ContentDescription" />

        <ImageButton
            android:id="@+id/btnEliminarDoctor"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/item_doctor_eliminar"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#EF4444"
            tools:ignore="ContentDescription" />

    </LinearLayout>
</androidx.cardview.widget.CardView>