<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    tools:context=".RegistroHistorial">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/registro_historial_titulo"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/etTipoMascota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/registro_historial_tipo_mascota"
            android:inputType="text"
            android:importantForAutofill="no"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:backgroundTint="#10B981"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etPesoHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/registro_historial_peso"
            android:inputType="numberDecimal"
            android:importantForAutofill="no"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:backgroundTint="#10B981"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etMedidas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/registro_historial_medidas"
            android:inputType="text"
            android:importantForAutofill="no"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:backgroundTint="#10B981"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etDolencia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/registro_historial_dolencia"
            android:inputType="textMultiLine"
            android:importantForAutofill="no"
            android:lines="3"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:backgroundTint="#10B981"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etDiagnostico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/registro_historial_diagnostico"
            android:inputType="textMultiLine"
            android:importantForAutofill="no"
            android:lines="3"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:backgroundTint="#10B981"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnGuardarHistorial"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/registro_historial_guardar"
            app:backgroundTint="#10B981"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>