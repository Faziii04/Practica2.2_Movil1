<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0F172A"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Welcome Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾 PetCare"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your pet's health, our priority"
                android:textSize="18sp"
                android:textColor="#CBD5E1"
                android:gravity="center"
                android:layout_marginBottom="56dp" />

            <!-- Register Buttons -->
            <Button
                android:id="@+id/registerDoctorButton"
                android:layout_width="280dp"
                android:layout_height="60dp"
                android:text="👨‍⚕️ Register as Doctor"
                app:backgroundTint="#6366F1"
                app:cornerRadius="12dp"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center" />

            <Button
                android:id="@+id/registerPetButton"
                android:layout_width="280dp"
                android:layout_height="60dp"
                android:text="🐶 Register as Pet Owner"
                app:backgroundTint="#EC4899"
                app:cornerRadius="12dp"
                android:layout_marginBottom="72dp"
                android:layout_gravity="center" />

            <!-- Login Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already a member?"
                android:textSize="16sp"
                android:textColor="#CBD5E1"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Pet Login -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pet Owner Login"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#EC4899"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/petNameLogin"
                android:layout_width="280dp"
                android:layout_height="48dp"
                android:hint="Pet Name"
                android:textColorHint="#64748B"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:background="#1E293B"
                android:layout_marginBottom="12dp"
                android:layout_gravity="center" />

            <EditText
                android:id="@+id/petPasswordLogin"
                android:layout_width="280dp"
                android:layout_height="48dp"
                android:hint="Password"
                android:textColorHint